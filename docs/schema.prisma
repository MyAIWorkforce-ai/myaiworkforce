// docs/schema.prisma

// Users & Authentication
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  createdAt DateTime  @default(now())
  profile   Profile?
  skills    Skill[]
  purchases Purchase[]
}

model Profile {
  id          String  @id @default(uuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])
  username    String  @unique
  displayName String?
  bio         String?
  avatarUrl   String?
  website     String?
}

// Marketplace Skills
model Skill {
  id          String     @id @default(uuid())
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  title       String
  description String
  price       Int        // in cents
  isFree      Boolean    @default(false)
  category    String     // e.g., "Sales", "Marketing"
  tags        String[]
  fileUrl     String     // Link to Supabase storage
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  purchases   Purchase[]
}

// Purchases & Downloads
model Purchase {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id])
  amount    Int      // in cents
  createdAt DateTime @default(now())
}
